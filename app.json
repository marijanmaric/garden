{
  "expo": {
    "name": "GartenApp",
    "slug": "garden-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "gartenapp",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.yourcompany.gartenapp"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2D6A4F"
      },
      "package": "com.yourcompany.gartenapp"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "GartenApp benötigt Kamerazugriff, um Pflanzen zu identifizieren."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "GartenApp benötigt Fotozugriff, um Pflanzen zu identifizieren."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "GartenApp benötigt Standortzugriff für lokale Wetterdaten."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
